# --- Local development (Docker Postgres) ---
DATABASE_URL=postgres://connectai:connectai@localhost:5432/connectai_poc

# 32+ char random string. Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-with-a-long-random-string

# Public base URL of the app. Local: http://localhost:3000
# Vercel: set to your production URL, e.g. https://your-app.vercel.app
BETTER_AUTH_URL=http://localhost:3000

# --- Production notes (Vercel) ---
# DATABASE_URL: use a hosted Postgres and prefer its POOLED connection string
#   (Neon pooler / Supabase transaction pooler / pgbouncer). Example:
#   postgres://user:pass@ep-xxx-pooler.region.aws.neon.tech/db?sslmode=require
# DB_POOL_MAX: keep the per-instance pool small on serverless (e.g. 1).
# DB_POOL_MAX=1
